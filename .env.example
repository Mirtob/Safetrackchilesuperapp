# ============================================================
# SafeTrack Chile — Plantilla de variables de entorno
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# ============================================================

# --- Supabase (auth + base de datos) ---
VITE_SUPABASE_URL=REEMPLAZA_CON_TU_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=REEMPLAZA_CON_TU_SUPABASE_ANON_KEY

# --- Google OAuth 2.0 (login vía Supabase) ---
VITE_GOOGLE_CLIENT_ID=REEMPLAZA_CON_TU_CLIENT_ID.apps.googleusercontent.com

# --- Google Maps JavaScript API ---
VITE_GOOGLE_MAPS_API_KEY=REEMPLAZA_CON_TU_MAPS_API_KEY
